<Window x:Class="ProposalAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tender Agent" Height="820" Width="1280" MinHeight="680" MinWidth="1040"
        Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Tender Agent" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Local proposal brain, brief analysis, and fake-org team fit"
                           Foreground="#52606D" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="UseAiCheckBox" Content="Use local Ollama" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button x:Name="RefreshButton" Content="Refresh tenders" Width="128" Height="34" Margin="0,0,8,0"
                        Click="RefreshButton_Click" />
                <Button x:Name="AnalyzeButton" Content="Analyze selected" Width="136" Height="34"
                        Click="AnalyzeButton_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Tender Watchlist" FontSize="16" FontWeight="SemiBold"
                               Margin="14,12,14,8" />
                    <ListBox x:Name="TenderList" Margin="10,0,10,10" BorderThickness="0"
                             SelectionChanged="TenderList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,8" BorderBrush="#E5EAF0" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TenderId}" FontSize="12" Foreground="#66788A" />
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Buyer}" FontSize="12" Foreground="#52606D" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ClosingLabel}" FontSize="12" Foreground="#9A3412" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="16,14,16,10">
                        <TextBlock x:Name="SelectedTitle" Text="Select a tender" FontSize="20" FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SelectedMeta" Text="Cached Nova Scotia tender briefs will appear here."
                                   Foreground="#52606D" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBox x:Name="ReportText" Grid.Row="1" Margin="16,0,16,12"
                             FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"
                             AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" IsReadOnly="True" />

                    <DockPanel Grid.Row="2" Margin="16,0,16,14">
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#52606D"
                                   Text="Ready." />
                        <Button x:Name="OpenOutputButton" DockPanel.Dock="Right" Width="132" Height="32"
                                Content="Open output" Click="OpenOutputButton_Click" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
